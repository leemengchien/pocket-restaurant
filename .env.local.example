# 複製這個檔案為 .env.local，填入你自己的金鑰

# Supabase（Project Settings → API）
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci你的anon_key

# Google Places API key（只在後端使用，「不要」加 NEXT_PUBLIC_ 前綴）
# 這把 key 是站長共用 key，所有使用者的 Google 搜尋都透過後端代理使用它
GOOGLE_PLACES_API_KEY=AIzaSy你的金鑰
